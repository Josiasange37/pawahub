# Fluxpay Backend - Environment Variables
# Copy this to .env and fill in values

# pawaPay (Mobile Money gateway)
PAWAPAY_API_TOKEN=your_pawapay_token
PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io

# Supabase (PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key

# Email (Gmail SMTP)
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# Resend (optional)
RESEND_API_KEY=re_your_key

# Auth
JWT_SECRET=your_jwt_secret_here

# Baileys WhatsApp Bot URL
# Local: http://localhost:3001
# Production: https://your-bot-service.up.railway.app
BAILEYS_BOT_URL=http://localhost:3001
